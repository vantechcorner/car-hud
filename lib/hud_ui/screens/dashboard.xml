<screen>
	<!--
		Layout is implemented in dashboard_gen.c (arc segment, observers, flex rows).
		Regenerating from XML may overwrite that file — merge manually if you use the editor.
	-->
	<styles>
		<style name="style_arc" arc_width="3" arc_rounded="false" arc_color="0xffffff" />
		<style name="style_arc_indicator" arc_width="30" arc_rounded="false" arc_color="0xffffff" />
		<style name="style_knob" bg_opa="0" />
	</styles>
	<view>
		<style name="style_dark" />
		<lv_arc
			align="top_mid"
			width="240"
			height="240"
			min_value="0"
			max_value="6000"
			bind_value="engine_rpm"
			clickable="false"
		>
			<style name="style_arc" />
			<style name="style_arc_indicator" selector="indicator" />
			<style name="style_knob" selector="knob" />
		</lv_arc>
		<lv_label bind_text="engine_rpm" align="top_mid" y="44" />
		<lv_label bind_text="speed" bind_text-fmt="%d" align="center" style_text_font="roboto_bold_150" y="14" />
		<lv_label text="km/h" align="center" y="96" style_text_font="roboto_regular_24" />
		<lv_label bind_text="coolant_temp" bind_text-fmt="%02d°C" align="bottom_left" x="12" y="-14" />
		<!-- battery: formatted in dashboard_gen.c (tenths → x.x V) -->
		<lv_label text="--.- V" align="bottom_right" x="-12" y="-14" />
		<lv_image src="warning" align="left_mid" x="26">
			<bind_flag_if_eq subject="can_error" flag="hidden" ref_value="0" />
		</lv_image>
		<lv_image src="disconnect" align="right_mid" x="-26">
			<bind_flag_if_eq subject="con_error" flag="hidden" ref_value="0" />
		</lv_image>
	</view>
</screen>
