	</previews>
	<styles>
		<style
			name="style_item"
			width="240"
			height="40"
			pad_all="0"
			pad_left="6"
			pad_right="6"
			border_width="1"
			text_color="0xfff"
			border_side="bottom"
			radius="0"
			bg_opa="0"
			layout="flex"
			flex_track_place="center"
			flex_cross_place="center"
		/>

		<style name="style_slider" width="100" />
